        "custom_liquid": "<div class=\"mrd-ed\"><div class=\"mrd-ed__in\"><p class=\"mrd-ed__k\">Made to be worn</p><h2 class=\"mrd-ed__h\">We start with the fabric and stop when it feels right. No logos, no noise , just pieces that get better the more you reach for them.</h2><a class=\"mrd-ed__a\" href=\"/collections/all\">Shop the edit</a></div></div><style>.mrd-ed{width:100vw;background:#E7E2D6;box-sizing:border-box;}.mrd-ed__in{max-width:880px;margin:0 auto;padding:84px 28px;text-align:center;color:#1c1b19;}.mrd-ed__k{margin:0 0 16px;font-size:.72rem;letter-spacing:.26em;text-transform:uppercase;opacity:.7;}.mrd-ed__h{margin:0 0 26px;font-weight:400;font-size:clamp(1.3rem,2.4vw,1.9rem);line-height:1.4;}.mrd-ed__a{display:inline-block;padding:12px 30px;background:#1c1b19;color:#fff;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;text-decoration:none;}.mrd-ed__a:hover{opacity:.85;}</style>",
