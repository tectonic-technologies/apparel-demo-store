{
  "sections": {
    "mrd_hero": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "\n<a class=\"mrd-hero\" href=\"/collections/all\">\n  {%- assign himg = collections['cat-dresses'].image | default: collections['women'].image -%}\n  <div class=\"mrd-hero__bg\" style=\"background-image:url('{{ himg | image_url: width: 2000 }}')\"></div>\n  <div class=\"mrd-hero__veil\"></div>\n  <div class=\"mrd-hero__inner\">\n    <p class=\"mrd-hero__ey\">The Summer Edit</p>\n    <h1 class=\"mrd-hero__h\">Considered essentials.<br>Nothing loud.</h1>\n    <div class=\"mrd-hero__cta\"><span class=\"mrd-btn\">Shop Men</span><span class=\"mrd-btn mrd-btn--g\" onclick=\"event.preventDefault();location.href='/collections/women'\">Shop Women</span></div>\n  </div>\n</a>\n<style>\n.mrd-hero{position:relative;display:block;width:100vw;min-height:560px;height:84vh;max-height:860px;overflow:hidden;color:#fff;text-decoration:none;}\n.mrd-hero__bg{position:absolute;inset:0;background-size:cover;background-position:center 18%;}\n.mrd-hero__veil{position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,19,17,.15),rgba(20,19,17,.45));}\n.mrd-hero__inner{position:absolute;left:0;right:0;bottom:9%;display:flex;flex-direction:column;align-items:center;gap:22px;text-align:center;padding:0 24px;}\n.mrd-hero__ey{margin:0;font-size:.72rem;letter-spacing:.28em;text-transform:uppercase;opacity:.92;}\n.mrd-hero__h{margin:0;font-weight:500;font-size:clamp(2.1rem,4.4vw,3.7rem);line-height:1.05;letter-spacing:.01em;}\n.mrd-hero__cta{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-top:6px;}\n.mrd-btn{display:inline-block;padding:13px 30px;background:#fff;color:#1c1b19;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;border:1px solid #fff;transition:.18s;}\n.mrd-btn--g{background:transparent;color:#fff;}\n.mrd-btn:hover{background:#1c1b19;color:#fff;border-color:#1c1b19;}\n.mrd-btn--g:hover{background:#fff;color:#1c1b19;}\n@media(max-width:749px){.mrd-hero{min-height:74vh;}}\n</style>\n",
        "section_width": "full-width",
        "background_color": "",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "mrd_gender": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"mrd-band\"><div class=\"mrd-wrap\"><h2 class=\"mrd-h2\">Shop by Category</h2><div class=\"mrd-grid mrd-grid--3\">{%- assign c = collections['men'] -%}{%- if c.image -%}<a class=\"mrd-tile\" href=\"{{ c.url }}\"><div class=\"mrd-tile__img\" style=\"background-image:url('{{ c.image | image_url: width: 900 }}')\"></div><span class=\"mrd-tile__lab\">Men<span class=\"mrd-tile__cta\">Shop</span></span></a>{%- endif -%}{%- assign c = collections['women'] -%}{%- if c.image -%}<a class=\"mrd-tile\" href=\"{{ c.url }}\"><div class=\"mrd-tile__img\" style=\"background-image:url('{{ c.image | image_url: width: 900 }}')\"></div><span class=\"mrd-tile__lab\">Women<span class=\"mrd-tile__cta\">Shop</span></span></a>{%- endif -%}{%- assign c = collections['unisex'] -%}{%- if c.image -%}<a class=\"mrd-tile\" href=\"{{ c.url }}\"><div class=\"mrd-tile__img\" style=\"background-image:url('{{ c.image | image_url: width: 900 }}')\"></div><span class=\"mrd-tile__lab\">Unisex<span class=\"mrd-tile__cta\">Shop</span></span></a>{%- endif -%}</div></div></div><style>.mrd-band{width:100vw;box-sizing:border-box;}.mrd-wrap{max-width:1360px;margin:0 auto;padding:60px 28px;}.mrd-h2{text-align:center;font-weight:500;font-size:1.45rem;letter-spacing:.02em;margin:0 0 30px;}.mrd-grid{display:grid;gap:14px;}.mrd-grid--3{grid-template-columns:repeat(3,1fr);}.mrd-grid--5{grid-template-columns:repeat(5,1fr);}.mrd-tile{position:relative;display:block;text-decoration:none;color:#1c1b19;overflow:hidden;}.mrd-tile__img{aspect-ratio:3/4;background-size:cover;background-position:center;background-color:#e7e2d6;transition:transform .5s ease;}.mrd-tile:hover .mrd-tile__img{transform:scale(1.04);}.mrd-tile__lab{position:absolute;left:0;right:0;bottom:16px;display:flex;flex-direction:column;gap:8px;align-items:center;color:#fff;font-size:.95rem;letter-spacing:.1em;text-transform:uppercase;text-shadow:0 1px 8px rgba(0,0,0,.35);}.mrd-tile__cta{font-size:.62rem;letter-spacing:.18em;border:1px solid rgba(255,255,255,.85);padding:5px 14px;}@media(max-width:749px){.mrd-grid--3,.mrd-grid--5{grid-template-columns:repeat(2,1fr);}}</style>",
