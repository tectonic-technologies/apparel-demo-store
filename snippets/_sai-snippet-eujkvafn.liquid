/* ── Add-to-cart loader ──────────────────────────────────────────────────── */

/* The button is the positioning context. While loading, the loader overlays
   the button content (label + inline total). Label is kept in the DOM but
   visibility:hidden so the button preserves its width. */
.sai-eujkvafn__cta {
  position: relative;
}

.sai-eujkvafn__loader {
  position: absolute;
  inset: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: currentColor;
  pointer-events: none;
}

.sai-eujkvafn__loader[hidden] {
  display: none;
}

.sai-eujkvafn__cta[data-loading="true"] > :not(.sai-eujkvafn__loader) {
  visibility: hidden;
}

.sai-eujkvafn__spinner {
  inline-size: var(--sai-eujkvafn-loader-size);
  block-size: var(--sai-eujkvafn-loader-size);
  animation: sai-eujkvafn-spin 0.8s linear infinite;
}

@keyframes sai-eujkvafn-spin {
  to {
    transform: rotate(360deg);
  }
}

@media (prefers-reduced-motion: reduce) {
  .sai-eujkvafn__spinner {
    animation-duration: 2s;
  }
}

/* Per-breakpoint layout toggle — only present when desktop and mobile layouts
   differ (otherwise a single element renders with neither class and shows at
   all widths). Kept at single-class (0,1,0) specificity and placed after the
   base `.sai-eujkvafn { display: block }` rule, so it wins by source order
   while a per-instance baked rule (anchored at (0,2,0)) still overrides it —
   honouring the author-selector specificity contract. 768px matches the
   horizontal layout's own desktop threshold. */
.sai-eujkvafn--web-only { display: block; }
.sai-eujkvafn--mweb-only { display: none; }
@media (max-width: 767.98px) {
  .sai-eujkvafn--web-only { display: none; }
  .sai-eujkvafn--mweb-only { display: block; }
}
{% endstylesheet %}

{%- assign content       = variant.content -%}
{%- assign heading       = content.heading       | default: 'Frequently Bought Together' | escape -%}
{%- assign cta_label     = content.cta_label     | default: 'Add To Cart' | escape -%}
{%- assign total_label   = content.total_label   | default: 'Total' | escape -%}
{%- assign total_subtext = content.total_subtext | default: 'Selected items will be added to cart.' | escape -%}
{%- assign section_description = content.section_description | default: '' | escape -%}

{%- assign lock_main = content.lock_main_product -%}
{%- if lock_main == nil -%}{%- assign lock_main = false -%}{%- endif -%}

{%- comment -%}
  The main product participates in the bundle when it's locked (always added)
  or its card is shown. `include_main` collapses the two:
    - locked + shown   → card visible, always added
    - locked + hidden  → card display:none (stays in DOM, still counted/added
                         silently); only its card is suppressed
    - unlocked + shown → card visible, selectable
    - unlocked + hidden→ excluded: main card not rendered, not counted, not
                         added — the bundle is add-ons only
  Every main-card render site and the SSR count gate on `include_main`.
{%- endcomment -%}
{%- assign show_main = content.show_main_product -%}
{%- if show_main == nil -%}{%- assign show_main = true -%}{%- endif -%}
{%- assign include_main = false -%}
{%- if lock_main or show_main -%}{%- assign include_main = true -%}{%- endif -%}

{%- assign show_total_price = content.show_total_price -%}
{%- if show_total_price == nil -%}{%- assign show_total_price = true -%}{%- endif -%}

{%- assign after_add_action = content.after_add_action -%}
{%- if after_add_action != 'stay' and after_add_action != 'redirect-to-cart' and after_add_action != 'redirect-to-checkout' -%}
  {%- assign after_add_action = 'stay' -%}
{%- endif -%}

{%- assign show_ratings = content.show_ratings -%}
{%- if show_ratings == nil -%}{%- assign show_ratings = true -%}{%- endif -%}

{%- assign show_discount_badge = content.show_discount_badge -%}
{%- if show_discount_badge == nil -%}{%- assign show_discount_badge = true -%}{%- endif -%}

{%- comment -%}
  Layout + select-prop allowlists. `| default:` is not enough — the merchant
  could POST any string. Validate against the allowed set and fall back to
  the safe default (fail-closed per .claude/rules/generated-liquid.md
  "Default-to-safe on missing/invalid render arguments").
{%- endcomment -%}
{%- comment -%}
  Preset id is the storage value; layout_class is the BEM modifier so the
  CSS reads as `--vertical` / `--horizontal` rather than the catalog's
  `default` preset name leaking into the markup.
{%- endcomment -%}
{%- comment -%}
  Layout is per-breakpoint. `layout` is the desktop/base layout; `layout_mobile`
  defaults to "inherit" → follows desktop, so existing instances (no
  layout_mobile value) render identically at every breakpoint. When the two
  resolve to different layouts, BOTH are rendered and a CSS viewport toggle
  (--web-only / --mweb-only) shows one per breakpoint.
{%- endcomment -%}
{%- assign layout_desktop = content.layout -%}
{%- if layout_desktop != 'default' and layout_desktop != 'horizontal' -%}
  {%- assign layout_desktop = 'default' -%}
{%- endif -%}
{%- assign layout_mobile = content.layout_mobile -%}
{%- if layout_mobile != 'default' and layout_mobile != 'horizontal' -%}
  {%- assign layout_mobile = layout_desktop -%}
{%- endif -%}
{%- if layout_desktop == layout_mobile -%}
  {%- assign sai_layouts = layout_desktop | split: '|' -%}
{%- else -%}
  {%- capture sai_layouts_csv -%}{{ layout_desktop }}|{{ layout_mobile }}{%- endcapture -%}
  {%- assign sai_layouts = sai_layouts_csv | split: '|' -%}
{%- endif -%}

{%- assign checkbox_default_state = content.checkbox_default_state -%}
{%- if checkbox_default_state != 'selected' and checkbox_default_state != 'unselected' -%}
  {%- assign checkbox_default_state = 'selected' -%}
{%- endif -%}
{%- assign default_checked = true -%}
{%- if checkbox_default_state == 'unselected' -%}{%- assign default_checked = false -%}{%- endif -%}

{%- assign image_aspect_ratio = content.image_aspect_ratio -%}
{%- if image_aspect_ratio != '1:1' and image_aspect_ratio != '4:3' and image_aspect_ratio != '3:4' -%}
  {%- assign image_aspect_ratio = '1:1' -%}
{%- endif -%}
{%- assign aspect_css = '1' -%}
{%- if image_aspect_ratio == '4:3' -%}{%- assign aspect_css = '4 / 3' -%}{%- endif -%}
{%- if image_aspect_ratio == '3:4' -%}{%- assign aspect_css = '3 / 4' -%}{%- endif -%}

{%- assign image_object_fit = content.image_object_fit -%}
{%- if image_object_fit != 'cover' and image_object_fit != 'contain' -%}
  {%- assign image_object_fit = 'cover' -%}
{%- endif -%}

{%- comment -%}
  aspect-ratio drives the *box* shape, so it must be applied to the parent
  `<a class="__media">` element. object-fit applies to the <img> itself —
  CSS only respects object-fit on replaced elements. Without this split, the
  inline style sits on a 100%×100%-filling img inside a fixed-shape parent,
  and aspect-ratio has nowhere to take effect.
{%- endcomment -%}
{%- assign media_style = 'aspect-ratio: ' | append: aspect_css | append: ';' -%}
{%- assign image_style = 'object-fit: ' | append: image_object_fit | append: ';' -%}

{%- assign fbt_handles = entry.content.recommendations -%}

{%- comment -%}
  Cap the number of recommendations shown. `max_recommendations` defaults to 3
  (new instances and legacy instances with no value alike). Slicing here — before
  the resolve pre-pass and every downstream loop (cards, payload, order) — keeps
  the rendered cards, the JSON payload, and the count consistent. A cap only ever
  trims: fewer recommendations than the cap render unchanged.
{%- endcomment -%}
{%- assign max_reco = content.max_recommendations -%}
{%- if max_reco == nil or max_reco == blank -%}
  {%- assign max_reco = 3 -%}
{%- else -%}
  {%- assign max_reco = max_reco | plus: 0 -%}
{%- endif -%}
{%- if max_reco < 1 -%}{%- assign max_reco = 1 -%}{%- endif -%}
{%- if fbt_handles != nil and fbt_handles.size > max_reco -%}
  {%- assign fbt_handles = fbt_handles | slice: 0, max_reco -%}
{%- endif -%}

{%- comment -%}
  Pre-pass: count handles that resolve to a real product drop.
  `all_products[h]` returns EmptyDrop (NOT nil) for unknown handles, so the
  safe test is `r == empty`. Used as the collapse gate so a payload of
  entirely-stale handles renders nothing.
{%- endcomment -%}
{%- assign resolved_count = 0 -%}
{%- if fbt_handles != nil -%}
  {%- for handle in fbt_handles -%}
    {%- assign r = all_products[handle] -%}
    {%- unless r == empty -%}
      {%- assign resolved_count = resolved_count | plus: 1 -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}

{%- if resolved_count == 0 -%}
  {%- comment -%} no recos — collapse widget; do not emit the script tag {%- endcomment -%}
{%- else -%}

<script src="{{ 'sai-snippet-eujkvafn.js' | asset_url }}" async></script>

{%- comment -%}
  SSR CTA count must match what the JS computes on hydration, or the
  merchant sees a flash of "Add To Cart (N)" before the count corrects.
  Locked main is always counted; default-unchecked starts at 0; the
  default-checked case includes main + resolved recos. An excluded main
  (unlocked + hidden) is never counted.
{%- endcomment -%}
{%- assign main_checked = false -%}
{%- if include_main and lock_main -%}{%- assign main_checked = true -%}{%- endif -%}
{%- if include_main and default_checked -%}{%- assign main_checked = true -%}{%- endif -%}
{%- assign total_count = 0 -%}
{%- if main_checked -%}{%- assign total_count = 1 -%}{%- endif -%}
{%- if default_checked -%}{%- assign total_count = total_count | plus: resolved_count -%}{%- endif -%}

{%- comment -%}
  Render one <sai-eujkvafn> per resolved layout. Single entry (desktop == mobile,
  incl. every legacy instance) → one element, no viewport class, shown at all
  widths (identical to the pre-per-breakpoint behavior). Two entries → desktop
  first (--web-only), mobile second (--mweb-only); each is an independent
  custom-element instance with its own payload, so the two coexist safely.
{%- endcomment -%}
{%- for sai_lo in sai_layouts -%}
{%- assign layout = sai_lo -%}
{%- assign layout_class = 'vertical' -%}
{%- if layout == 'horizontal' -%}{%- assign layout_class = 'horizontal' -%}{%- endif -%}
{%- assign sai_vp_class = '' -%}
{%- if sai_layouts.size > 1 -%}
  {%- if forloop.first -%}{%- assign sai_vp_class = ' sai-eujkvafn--web-only' -%}{%- else -%}{%- assign sai_vp_class = ' sai-eujkvafn--mweb-only' -%}{%- endif -%}
{%- endif -%}
<sai-eujkvafn class="sai-eujkvafn sai-eujkvafn--{{ layout_class }}{{ sai_vp_class }}">
  <div class="sai-eujkvafn__inner">
    <h2 class="sai-eujkvafn__heading">{{ heading }}</h2>
    {%- if section_description != '' -%}
      <p class="sai-eujkvafn__description">{{ section_description }}</p>
    {%- endif -%}

    {%- if layout == 'horizontal' -%}

    {%- comment -%} ── Horizontal layout: cards row + side total panel ─────── {%- endcomment -%}
    <div class="sai-eujkvafn__layout">
      <div class="sai-eujkvafn__cards">

        {%- if include_main -%}
        <div class="sai-eujkvafn__card sai-eujkvafn__card--main{% unless show_main %} sai-eujkvafn__card--hidden{% endunless %}" data-product-id="{{ product.id }}">
          <label class="sai-eujkvafn__checkbox{% if lock_main %} sai-eujkvafn__checkbox--locked{% endif %}">
            <input type="checkbox" data-fbt-checkbox
              {% if lock_main or default_checked %}checked{% endif %}
              aria-label="Include {{ product.title | escape }}"
              {% if lock_main %}disabled{% endif %}>
            <span class="sai-eujkvafn__checkbox-mark" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false">
                <path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </label>
          <a class="sai-eujkvafn__media" href="{{ product.url }}" style="{{ media_style }}" tabindex="-1" aria-hidden="true">
            {%- if product.featured_image -%}
              <img
                class="sai-eujkvafn__image"
                src="{{ product.featured_image | image_url: width: 400 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                style="{{ image_style }}"
                loading="lazy"
              >
            {%- endif -%}
          </a>
          <a class="sai-eujkvafn__title" href="{{ product.url }}">{{ product.title }}</a>
          <div class="sai-eujkvafn__price-row">
            <span class="sai-eujkvafn__price">{{ product.price | money }}</span>
            {%- if product.compare_at_price and product.compare_at_price > product.price -%}
              <span class="sai-eujkvafn__compare">{{ product.compare_at_price | money }}</span>
              {%- if show_discount_badge -%}
                {%- assign p_off_amount = product.compare_at_price | minus: product.price -%}
                {%- assign p_off_pct = p_off_amount | times: 100 | divided_by: product.compare_at_price -%}
                <span class="sai-eujkvafn__off-badge">{{ p_off_pct }}% OFF</span>
              {%- endif -%}
            {%- endif -%}
          </div>
          {%- if product.variants.size > 1 -%}
            <button type="button" class="sai-eujkvafn__variant-trigger" data-variant-trigger aria-haspopup="dialog">
              <span class="sai-eujkvafn__variant-label">{{ product.variants.first.title }}</span>
              <svg class="sai-eujkvafn__chevron" width="12" height="12" viewBox="0 0 14 14" fill="none" focusable="false" aria-hidden="true">
                <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          {%- endif -%}
        </div>
        {%- endif -%}

        {%- for handle in fbt_handles -%}
          {%- assign r = all_products[handle] -%}
          {%- if r == empty -%}{%- continue -%}{%- endif -%}
          {%- if forloop.first and include_main -%}
            <div class="sai-eujkvafn__plus" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false">
                <path d="M7 2V12M2 7H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
          {%- endif -%}
          <div class="sai-eujkvafn__card sai-eujkvafn__card--reco" data-product-id="{{ r.id }}">
            <label class="sai-eujkvafn__checkbox">
              <input type="checkbox" data-fbt-checkbox {% if default_checked %}checked{% endif %} aria-label="Include {{ r.title | escape }}">
              <span class="sai-eujkvafn__checkbox-mark" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false">
                  <path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </label>
            <a class="sai-eujkvafn__media" href="{{ r.url }}" style="{{ media_style }}" tabindex="-1" aria-hidden="true">
              {%- if r.featured_image -%}
                <img
                  class="sai-eujkvafn__image"
                  src="{{ r.featured_image | image_url: width: 400 }}"
                  alt="{{ r.featured_image.alt | default: r.title | escape }}"
                  style="{{ image_style }}"
                  loading="lazy"
                >
              {%- endif -%}
            </a>
            <a class="sai-eujkvafn__title" href="{{ r.url }}">{{ r.title }}</a>
            <div class="sai-eujkvafn__price-row">
              <span class="sai-eujkvafn__price">{{ r.price | money }}</span>
              {%- if r.compare_at_price and r.compare_at_price > r.price -%}
                <span class="sai-eujkvafn__compare">{{ r.compare_at_price | money }}</span>
                {%- if show_discount_badge -%}
                  {%- assign r_off_amount = r.compare_at_price | minus: r.price -%}
                  {%- assign r_off_pct = r_off_amount | times: 100 | divided_by: r.compare_at_price -%}
                  <span class="sai-eujkvafn__off-badge">{{ r_off_pct }}% OFF</span>
                {%- endif -%}
              {%- endif -%}
            </div>
            {%- if r.variants.size > 1 -%}
              <button type="button" class="sai-eujkvafn__variant-trigger" data-variant-trigger aria-haspopup="dialog">
                <span class="sai-eujkvafn__variant-label">{{ r.variants.first.title }}</span>
                <svg class="sai-eujkvafn__chevron" width="12" height="12" viewBox="0 0 14 14" fill="none" focusable="false" aria-hidden="true">
                  <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <aside class="sai-eujkvafn__total sai-eujkvafn__total--panel">
        {%- if show_total_price -%}
          <div class="sai-eujkvafn__total-heading">{{ total_label }}</div>
          <div class="sai-eujkvafn__total-row">
            <div class="sai-eujkvafn__total-subtext">{{ total_subtext }}</div>
            <div class="sai-eujkvafn__total-amount" data-fbt-total></div>
          </div>
        {%- endif -%}
        <button type="button" class="sai-eujkvafn__cta" data-fbt-cta>
          <span data-fbt-cta-label>{{ cta_label }} ({{ total_count }})</span>
          <span class="sai-eujkvafn__loader" data-fbt-loader hidden aria-hidden="true">
            <svg class="sai-eujkvafn__spinner" viewBox="0 0 24 24" fill="none" focusable="false">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-opacity="0.25" stroke-width="3"/>
              <path d="M22 12a10 10 0 0 0-10-10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="sai-eujkvafn__error" data-fbt-error role="alert" hidden></div>
      </aside>
    </div>

    {%- else -%}

    {%- comment -%} ── Vertical layout: stacked cards + full-width CTA below ── {%- endcomment -%}
    {%- if include_main -%}
    <div class="sai-eujkvafn__card sai-eujkvafn__card--main{% unless show_main %} sai-eujkvafn__card--hidden{% endunless %}" data-product-id="{{ product.id }}">
      <div class="sai-eujkvafn__sub-header">Product on this page</div>
      <div class="sai-eujkvafn__row">
        <a class="sai-eujkvafn__media" href="{{ product.url }}" style="{{ media_style }}" tabindex="-1" aria-hidden="true">
          {%- if product.featured_image -%}
            <img
              class="sai-eujkvafn__image"
              src="{{ product.featured_image | image_url: width: 200 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              style="{{ image_style }}"
              loading="lazy"
            >
          {%- endif -%}
        </a>
        <div class="sai-eujkvafn__info">
          <a class="sai-eujkvafn__title" href="{{ product.url }}">{{ product.title }}</a>
          <div class="sai-eujkvafn__price-row">
            <span class="sai-eujkvafn__price">{{ product.price | money }}</span>
            {%- if product.compare_at_price and product.compare_at_price > product.price -%}
              {%- assign p_off_amount = product.compare_at_price | minus: product.price -%}
              {%- assign p_off_pct = p_off_amount | times: 100 | divided_by: product.compare_at_price -%}
              <span class="sai-eujkvafn__compare">{{ product.compare_at_price | money }}</span>
              {%- if show_discount_badge -%}
                <span class="sai-eujkvafn__off-badge">{{ p_off_pct }}% OFF</span>
              {%- endif -%}
            {%- endif -%}
          </div>
          {%- if product.variants.size > 1 -%}
            <button type="button" class="sai-eujkvafn__variant-trigger" data-variant-trigger aria-haspopup="dialog">
              <span class="sai-eujkvafn__variant-label">{{ product.variants.first.title }}</span>
              <svg class="sai-eujkvafn__chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false" aria-hidden="true">
                <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          {%- endif -%}
        </div>
        <div class="sai-eujkvafn__select">
          <label class="sai-eujkvafn__checkbox{% if lock_main %} sai-eujkvafn__checkbox--locked{% endif %}">
            <input type="checkbox" data-fbt-checkbox
              {% if lock_main or default_checked %}checked{% endif %}
              aria-label="Include {{ product.title | escape }}"
              {% if lock_main %}disabled{% endif %}>
            <span class="sai-eujkvafn__checkbox-mark" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false">
                <path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </label>
          {%- if show_ratings and product.metafields.reviews.rating.value.rating -%}
            <span class="sai-eujkvafn__rating" aria-label="Rating">
              <svg width="14" height="14" viewBox="0 0 14 14" focusable="false" aria-hidden="true">
                <path d="M7 1L8.8 4.8L13 5.4L10 8.3L10.7 12.5L7 10.5L3.3 12.5L4 8.3L1 5.4L5.2 4.8L7 1Z" fill="currentColor"/>
              </svg>
              <span>{{ product.metafields.reviews.rating.value.rating | round: 1 }}</span>
            </span>
          {%- endif -%}
        </div>
      </div>
    </div>
    {%- endif -%}

    {%- for handle in fbt_handles -%}
      {%- assign r = all_products[handle] -%}
      {%- if r == empty -%}{%- continue -%}{%- endif -%}
      <div class="sai-eujkvafn__card sai-eujkvafn__card--reco" data-product-id="{{ r.id }}">
        <div class="sai-eujkvafn__row">
          <a class="sai-eujkvafn__media" href="{{ r.url }}" style="{{ media_style }}" tabindex="-1" aria-hidden="true">
            {%- if r.featured_image -%}
              <img
                class="sai-eujkvafn__image"
                src="{{ r.featured_image | image_url: width: 200 }}"
                alt="{{ r.featured_image.alt | default: r.title | escape }}"
                style="{{ image_style }}"
                loading="lazy"
              >
            {%- endif -%}
          </a>
          <div class="sai-eujkvafn__info">
            <a class="sai-eujkvafn__title" href="{{ r.url }}">{{ r.title }}</a>
            <div class="sai-eujkvafn__price-row">
              <span class="sai-eujkvafn__price">{{ r.price | money }}</span>
              {%- if r.compare_at_price and r.compare_at_price > r.price -%}
                {%- assign r_off_amount = r.compare_at_price | minus: r.price -%}
                {%- assign r_off_pct = r_off_amount | times: 100 | divided_by: r.compare_at_price -%}
                <span class="sai-eujkvafn__compare">{{ r.compare_at_price | money }}</span>
                {%- if show_discount_badge -%}
                  <span class="sai-eujkvafn__off-badge">{{ r_off_pct }}% OFF</span>
                {%- endif -%}
              {%- endif -%}
            </div>
            {%- if r.variants.size > 1 -%}
              <button type="button" class="sai-eujkvafn__variant-trigger" data-variant-trigger aria-haspopup="dialog">
                <span class="sai-eujkvafn__variant-label">{{ r.variants.first.title }}</span>
                <svg class="sai-eujkvafn__chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false" aria-hidden="true">
                  <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            {%- endif -%}
          </div>
          <div class="sai-eujkvafn__select">
            <label class="sai-eujkvafn__checkbox">
              <input type="checkbox" data-fbt-checkbox {% if default_checked %}checked{% endif %} aria-label="Include {{ r.title | escape }}">
              <span class="sai-eujkvafn__checkbox-mark" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" focusable="false">
                  <path d="M3 7L6 10L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </label>
            {%- if show_ratings and r.metafields.reviews.rating.value.rating -%}
              <span class="sai-eujkvafn__rating" aria-label="Rating">
                <svg width="14" height="14" viewBox="0 0 14 14" focusable="false" aria-hidden="true">
                  <path d="M7 1L8.8 4.8L13 5.4L10 8.3L10.7 12.5L7 10.5L3.3 12.5L4 8.3L1 5.4L5.2 4.8L7 1Z" fill="currentColor"/>
                </svg>
                <span>{{ r.metafields.reviews.rating.value.rating | round: 1 }}</span>
              </span>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}

    <button type="button" class="sai-eujkvafn__cta sai-eujkvafn__cta--vertical" data-fbt-cta>
      <span data-fbt-cta-label>{{ cta_label }} ({{ total_count }})</span>
      {%- if show_total_price -%}
        <span class="sai-eujkvafn__total sai-eujkvafn__total--inline">
          <span class="sai-eujkvafn__total-inline-label">{{ total_label }}</span>
          <span class="sai-eujkvafn__total-separator" aria-hidden="true">—</span>
          <span class="sai-eujkvafn__total-amount" data-fbt-total></span>
        </span>
      {%- endif -%}
      <span class="sai-eujkvafn__loader" data-fbt-loader hidden aria-hidden="true">
        <svg class="sai-eujkvafn__spinner" viewBox="0 0 24 24" fill="none" focusable="false">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-opacity="0.25" stroke-width="3"/>
          <path d="M22 12a10 10 0 0 0-10-10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        </svg>
      </span>
    </button>

    <div class="sai-eujkvafn__error" data-fbt-error role="alert" hidden></div>

    {%- endif -%}

    {%- comment -%}
      JSON payload. Per-value `| json` is mandatory inside <script type="application/json">:
      Liquid's `| json` filter unicode-escapes `<`, `>`, line separators, so
      values containing `</script>` or `<!--` survive intact as JSON but
      cannot terminate the surrounding <script> element. The JS reads this
      once on init and builds an id-keyed Map for O(1) lookup.
    {%- endcomment -%}
    <script type="application/json" data-fbt-payload>
{
  "main": {{ product.id | json }},
  "currency": {{ shop.currency | json }},
  "afterAddAction": {{ after_add_action | json }},
  {%- comment -%} Omit the main product from `order` when excluded (unlocked + hidden) so the JS builds no row for it — it's neither counted nor added. The main object stays in `products` below (an unused map entry; the JS only builds rows from `order`). {%- endcomment -%}
  "order": [{%- assign order_emitted = false -%}{%- if include_main -%}{{ product.id | json }}{%- assign order_emitted = true -%}{%- endif -%}{%- for handle in fbt_handles -%}{%- assign r = all_products[handle] -%}{%- if r == empty -%}{%- continue -%}{%- endif -%}{%- if order_emitted -%},{%- endif -%}{{ r.id | json }}{%- assign order_emitted = true -%}{%- endfor -%}],
  "products": [
    {
      "id": {{ product.id | json }},
      "title": {{ product.title | json }},
      "url": {{ product.url | json }},
      "imageUrl": {%- if product.featured_image -%}{{ product.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},
      "price": {{ product.price | json }},
      "compareAtPrice": {{ product.compare_at_price | json }},
      "options": {{ product.options | json }},
      "available": {{ product.available | json }},
      "variants": [
        {%- for v in product.variants -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {
            "id": {{ v.id | json }},
            "title": {{ v.title | json }},
            "price": {{ v.price | json }},
            "compareAtPrice": {{ v.compare_at_price | json }},
            "available": {{ v.available | json }},
            "options": {{ v.options | json }},
            "inventoryQty": {{ v.inventory_quantity | json }},
            "inventoryManaged": {{ v.inventory_management | json }}
          }
        {%- endfor -%}
      ]
    }
    {%- for handle in fbt_handles -%}
    {%- assign r = all_products[handle] -%}
    {%- if r == empty -%}{%- continue -%}{%- endif -%}
    ,
    {
      "id": {{ r.id | json }},
      "title": {{ r.title | json }},
      "url": {{ r.url | json }},
      "imageUrl": {%- if r.featured_image -%}{{ r.featured_image | image_url: width: 400 | json }}{%- else -%}null{%- endif -%},
      "price": {{ r.price | json }},
      "compareAtPrice": {{ r.compare_at_price | json }},
      "options": {{ r.options | json }},
      "available": {{ r.available | json }},
      "variants": [
        {%- for v in r.variants -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {
            "id": {{ v.id | json }},
            "title": {{ v.title | json }},
            "price": {{ v.price | json }},
            "compareAtPrice": {{ v.compare_at_price | json }},
            "available": {{ v.available | json }},
            "options": {{ v.options | json }},
            "inventoryQty": {{ v.inventory_quantity | json }},
            "inventoryManaged": {{ v.inventory_management | json }}
          }
        {%- endfor -%}
      ]
    }
    {%- endfor -%}
  ]
}
    </script>
  </div>
</sai-eujkvafn>
{%- endfor -%}

{%- endif -%}
