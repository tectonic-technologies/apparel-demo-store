{% doc %}
  Frequently Bought Together — bundle widget on the PDP.

  Two layouts: `vertical` (cards stacked above CTA, total inline in CTA)
  and `horizontal` (cards side by side with `+` separators, right-side
  Total panel hosting the CTA). Selection / variant picker / batched
  cart-add are identical across both.

  @param entry                {SlotEnvelopeEntry} Resolved default entry
                                                  from spectrum.fbt_<draft|live>;
                                                  `entry.content.recommendations`
                                                  is the array of product
                                                  handles to render as
                                                  recommendations.
  @param variant              {Metaobject}        Default variant from
                                                  spectrum_snippet_instance;
                                                  `variant.content` carries
                                                  merchant-edited props.
  @param mo                   {Metaobject}        spectrum_snippet_instance
                                                  metaobject drop.
  @param mutation_handle      {string}            'mut-{instanceId}' —
                                                  consumed by the wrapper's
                                                  outer div, not this body.
  @param experience_handle    {string}            Consumed by the wrapper's
                                                  outer div.
{% enddoc %}

{%- comment -%}
  Liquid globals used inside this snippet (NOT render args — Shopify-native):
    - product            : the page's main product (PDP context).
    - all_products       : handle-keyed product lookup. Capped at 20 unique
                           handles per page across the whole render — well
                           above the FBT count.
    - shop               : currency code threaded into the JSON payload.

  Empty / nil `entry.content.recommendations` collapses the whole widget.

  Trust boundary: this snippet does NOT receive merchant-authored HTML —
  every text prop (`heading`, `cta_label`, `section_description`,
  `total_label`, `total_subtext`) is run through `| escape` defensively so
  a merchant who pastes markup into a text field can't break the page
  layout or inject content.
{%- endcomment -%}

{% stylesheet %}
/* =============================================================================
 * Frequently Bought Together (eujkvafn) — combined vertical + horizontal CSS.
 *
 * Shared rules live at the .sai-eujkvafn root; layout-specific rules are
 * nested under .sai-eujkvafn--vertical / .sai-eujkvafn--horizontal. Single
 * author selectors stay at specificity (0,1,0) so per-instance baked rules
 * (anchored on [data-spectrum-instance-id][data-spectrum-variant-id]) always
 * win the cascade.
 *
 * Color tokens use --sai-eujkvafn-* custom properties so the Studio
 * per-instance style panel can override them. Fonts/spacing/radius come from
 * the theme's --sai-* design tokens — never hardcoded.
 * ============================================================================= */

.sai-eujkvafn,
.sai-eujkvafn__modal-overlay {
  --sai-eujkvafn-card-bg: #F4F1EA;
  --sai-eujkvafn-card-border: rgba(0, 0, 0, 0.1);
  --sai-eujkvafn-card-radius: 12px;
  --sai-eujkvafn-sub-header-bg: #f4f4f4;
  --sai-eujkvafn-checkbox-size: 1.5rem;
  --sai-eujkvafn-image-size: 5.5rem;
  --sai-eujkvafn-card-w: 11.5rem;
  --sai-eujkvafn-image-h: 12rem;
  --sai-eujkvafn-plus-size: 1.75rem;
  --sai-eujkvafn-off-bg: #0e6f54;
  --sai-eujkvafn-off-fg: #ffffff;
  --sai-eujkvafn-rating-fg: #f5b013;
  --sai-eujkvafn-low-stock-fg: #d24207;
  --sai-eujkvafn-fg: var(--sai-color-fg, #121212);
  --sai-eujkvafn-muted-fg: rgba(0, 0, 0, 0.55);
  --sai-eujkvafn-cta-bg: transparent;
  --sai-eujkvafn-cta-fg: #121212;
  --sai-eujkvafn-cta-border: #121212;
  --sai-eujkvafn-cta-hover-bg: #000000;
  --sai-eujkvafn-cta-hover-fg: #ffffff;
  --sai-eujkvafn-modal-overlay-bg: rgba(0, 0, 0, 0.55);
  --sai-eujkvafn-modal-card-bg: #ffffff;
  --sai-eujkvafn-pill-bg: #ededed;
  --sai-eujkvafn-pill-fg: #121212;
  --sai-eujkvafn-pill-selected-bg: #121212;
  --sai-eujkvafn-pill-selected-fg: #ffffff;
  --sai-eujkvafn-pill-disabled-fg: rgba(0, 0, 0, 0.45);
  --sai-eujkvafn-done-bg: #121212;
  --sai-eujkvafn-done-fg: #ffffff;
  --sai-eujkvafn-loader-size: 1.125rem;
}

.sai-eujkvafn {
  display: block;
  box-sizing: border-box;
  inline-size: 100%;
  margin-inline: auto;
  margin-block: var(--sai-size-6);
  font-family: var(--sai-font-body);
  font-size: 1rem;
  line-height: 1.4;
  color: var(--sai-eujkvafn-fg);
}

.sai-eujkvafn--vertical {
  max-inline-size: 56rem;
  padding-inline: var(--sai-size-4);
  font-size: 1.0625rem;
  line-height: 1.45;
}

.sai-eujkvafn--horizontal {
  max-inline-size: 75rem;
}

.sai-eujkvafn *,
.sai-eujkvafn *::before,
.sai-eujkvafn *::after {
  box-sizing: border-box;
}

.sai-eujkvafn__inner {
  inline-size: 100%;
  box-sizing: border-box;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__inner {
  padding-inline: var(--sai-size-4);
}

.sai-eujkvafn__heading {
  font-family: var(--sai-font-heading, var(--sai-font-body));
  font-size: 1.625rem;
  font-weight: var(--sai-font-body-weight-bold, 700);
  margin-block: 0 var(--sai-size-3);
  letter-spacing: -0.01em;
  line-height: 1.2;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__heading {
  margin-block: 0 var(--sai-size-4);
}

.sai-eujkvafn__description {
  margin: 0 0 var(--sai-size-4) 0;
  font-size: 0.875rem;
  color: var(--sai-eujkvafn-muted-fg);
  line-height: 1.4;
}

/* ── Cards (shared base) ─────────────────────────────────────────────────── */

.sai-eujkvafn__card {
  background: var(--sai-eujkvafn-card-bg);
  border: 1px solid var(--sai-eujkvafn-card-border);
  border-radius: var(--sai-eujkvafn-card-radius);
  overflow: hidden;
}

.sai-eujkvafn__title {
  color: inherit;
  text-decoration: none;
  font-weight: var(--sai-font-body-weight-bold, 600);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sai-eujkvafn__title:hover {
  text-decoration: underline;
}

.sai-eujkvafn__price-row {
  display: flex;
  gap: var(--sai-size-2);
  flex-wrap: wrap;
}

.sai-eujkvafn__price {
  font-weight: var(--sai-font-body-weight-bold, 600);
}

.sai-eujkvafn__compare {
  text-decoration: line-through;
  color: var(--sai-eujkvafn-muted-fg);
}

.sai-eujkvafn__off-badge {
  background: var(--sai-eujkvafn-off-bg);
  color: var(--sai-eujkvafn-off-fg);
  border-radius: var(--sai-radius-round);
  padding: 0.1875rem var(--sai-size-2);
  font-size: 0.8125rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  letter-spacing: 0.02em;
}

.sai-eujkvafn__variant-trigger {
  appearance: none;
  background: transparent;
  border: 1px solid var(--sai-eujkvafn-card-border);
  color: inherit;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sai-size-2);
  font: inherit;
  text-align: start;
}

.sai-eujkvafn__variant-trigger:hover {
  background: rgba(0, 0, 0, 0.03);
}

.sai-eujkvafn__variant-label {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sai-eujkvafn__chevron {
  flex-shrink: 0;
  color: var(--sai-eujkvafn-muted-fg);
}

/* ── Vertical layout ─────────────────────────────────────────────────────── */

.sai-eujkvafn--vertical .sai-eujkvafn__card {
  margin-block-end: var(--sai-size-3);
}

.sai-eujkvafn--vertical .sai-eujkvafn__card--main {
  border-color: rgba(0, 0, 0, 0.16);
}

.sai-eujkvafn--vertical .sai-eujkvafn__sub-header {
  background: var(--sai-eujkvafn-sub-header-bg);
  font-size: 1rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  padding: var(--sai-size-3) var(--sai-size-4);
}

.sai-eujkvafn--vertical .sai-eujkvafn__row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: var(--sai-size-4);
  padding: var(--sai-size-4);
}

.sai-eujkvafn--vertical .sai-eujkvafn__media {
  display: block;
  inline-size: var(--sai-eujkvafn-image-size);
  /* block-size driven by the inline `aspect-ratio` style on this element
     (set from the merchant's image_aspect_ratio prop). Fixed block-size
     here would override the prop. */
  block-size: auto;
  border-radius: var(--sai-radius-2);
  overflow: hidden;
  background: rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.sai-eujkvafn--vertical .sai-eujkvafn__image {
  inline-size: 100%;
  block-size: 100%;
  object-fit: cover;
  display: block;
}

.sai-eujkvafn--vertical .sai-eujkvafn__info {
  min-inline-size: 0;
  display: flex;
  flex-direction: column;
  gap: var(--sai-size-2);
}

.sai-eujkvafn--vertical .sai-eujkvafn__title {
  font-size: 1.0625rem;
}

.sai-eujkvafn--vertical .sai-eujkvafn__price-row {
  align-items: center;
  font-size: 1rem;
}

.sai-eujkvafn--vertical .sai-eujkvafn__variant-trigger {
  border-radius: var(--sai-radius-round);
  padding: 0.5rem var(--sai-size-3);
  font-size: 0.9375rem;
  inline-size: fit-content;
  max-inline-size: 100%;
  min-inline-size: 9rem;
}

.sai-eujkvafn--vertical .sai-eujkvafn__select {
  display: flex;
  flex-direction: column;
  align-items: end;
  gap: var(--sai-size-3);
  align-self: stretch;
  justify-content: space-between;
}

.sai-eujkvafn--vertical .sai-eujkvafn__checkbox {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  inline-size: var(--sai-eujkvafn-checkbox-size);
  block-size: var(--sai-eujkvafn-checkbox-size);
  border-radius: var(--sai-radius-2);
  cursor: pointer;
  position: relative;
  background: transparent;
  border: 1.5px solid rgba(0, 0, 0, 0.25);
  transition: background var(--sai-duration-1) var(--sai-ease-out-1), border-color
    var(--sai-duration-1) var(--sai-ease-out-1);
}

.sai-eujkvafn--vertical .sai-eujkvafn__checkbox:has(input:checked) {
  background: var(--sai-color-primary);
  border-color: var(--sai-color-primary);
}

.sai-eujkvafn--vertical .sai-eujkvafn__checkbox:has(input:checked) .sai-eujkvafn__checkbox-mark {
  color: var(--sai-color-primary-fg);
}

.sai-eujkvafn--vertical .sai-eujkvafn__checkbox:has(input:focus-visible) {
  outline: 2px solid var(--sai-color-primary);
  outline-offset: 2px;
}

.sai-eujkvafn__checkbox input {
  position: absolute;
  opacity: 0;
  inset: 0;
  margin: 0;
  cursor: pointer;
}

.sai-eujkvafn__checkbox-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  color: transparent;
}

/* Hide the entire checkbox cell when the main product is locked. The hidden
   <input> stays in the DOM (still checked by SSR + locked) so JS row-init
   counts the main as selected — but the user sees no checkbox at all. */
.sai-eujkvafn__checkbox--locked {
  display: none !important;
}

/* Hide the whole main-product card while keeping it in the DOM. Used when the
   main product is locked but its card is suppressed: the card's checkbox stays
   present (checked + disabled) so JS still counts it and adds it to cart. */
.sai-eujkvafn__card--hidden {
  display: none !important;
}

.sai-eujkvafn__rating {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.9375rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
}

.sai-eujkvafn__rating svg {
  inline-size: 1rem;
  block-size: 1rem;
  color: var(--sai-eujkvafn-rating-fg);
}

/* ── Horizontal layout ───────────────────────────────────────────────────── */

.sai-eujkvafn--horizontal .sai-eujkvafn__layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: var(--sai-size-4);
  align-items: stretch;
}

@media (min-width: 768px) {
  .sai-eujkvafn--horizontal .sai-eujkvafn__layout {
    grid-template-columns: minmax(0, 1fr) 26rem;
    gap: var(--sai-size-5);
  }
}

.sai-eujkvafn--horizontal .sai-eujkvafn__cards {
  display: flex;
  align-items: stretch;
  gap: 1rem;
  inline-size: 100%;
  min-inline-size: 0;
  scrollbar-width: thin;
  padding-block: 0.25rem;
  -webkit-overflow-scrolling: touch;
}

@media (max-width: 560px) {
  .sai-eujkvafn--horizontal .sai-eujkvafn__cards {
    overflow-x: auto;
  }
}

.sai-eujkvafn--horizontal .sai-eujkvafn__cards::-webkit-scrollbar {
  block-size: 6px;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__cards::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 999px;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__plus {
  display: flex;
  align-items: center;
  justify-content: center;
  inline-size: var(--sai-eujkvafn-plus-size);
  block-size: var(--sai-eujkvafn-plus-size);
  border-radius: 999px;
  border: 1px solid var(--sai-eujkvafn-card-border);
  background: var(--sai-eujkvafn-card-bg);
  color: var(--sai-eujkvafn-fg);
  align-self: center;
  flex-shrink: 0;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__card {
  position: relative;
  flex: 1 1 0;
  min-inline-size: 9.5rem;
  display: flex;
  flex-direction: column;
  gap: var(--sai-size-2);
  padding: var(--sai-size-3);
}

@media (max-width: 560px) {
  .sai-eujkvafn--horizontal .sai-eujkvafn__card {
    flex: 0 0 11rem;
  }
}

/* Horizontal checkbox overlays the top-left of the card image. */
.sai-eujkvafn--horizontal .sai-eujkvafn__checkbox {
  position: absolute;
  inset-block-start: 0.625rem;
  inset-inline-start: 0.625rem;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  inline-size: 1.375rem;
  block-size: 1.375rem;
  border-radius: 4px;
  cursor: pointer;
  background: #ffffff;
  border: 1.5px solid rgba(0, 0, 0, 0.35);
  transition: background 120ms ease, border-color 120ms ease;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__checkbox:has(input:checked) {
  background: var(--sai-color-primary, #121212);
  border-color: var(--sai-color-primary, #121212);
}

.sai-eujkvafn--horizontal .sai-eujkvafn__checkbox:has(input:checked) .sai-eujkvafn__checkbox-mark {
  color: var(--sai-color-primary-fg, #ffffff);
}

.sai-eujkvafn--horizontal .sai-eujkvafn__checkbox:has(input:focus-visible) {
  outline: 2px solid var(--sai-color-primary, #121212);
  outline-offset: 2px;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__media {
  display: block;
  inline-size: 100%;
  /* aspect-ratio set inline from the merchant's image_aspect_ratio prop.
     Don't hardcode it here — the inline style would still win, but a CSS
     default here makes the prop look broken when the inline value isn't
     present (e.g. during template edits). */
  block-size: auto;
  border-radius: 8px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.04);
}

.sai-eujkvafn--horizontal .sai-eujkvafn__image {
  inline-size: 100%;
  block-size: 100%;
  object-fit: cover;
  display: block;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__title {
  font-size: 0.875rem;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__price-row {
  align-items: baseline;
  font-size: 0.9375rem;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__compare {
  font-size: 0.8125rem;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__variant-trigger {
  border-radius: 8px;
  padding: 0.4375rem var(--sai-size-2);
  font-size: 0.8125rem;
  inline-size: 100%;
  margin-block-start: auto;
}

/* ── Total panel + CTA (shared visual + layout overrides) ────────────────── */

.sai-eujkvafn__cta {
  appearance: none;
  inline-size: 100%;
  background: var(--sai-eujkvafn-cta-bg);
  color: var(--sai-eujkvafn-cta-fg);
  border: 1.5px solid var(--sai-eujkvafn-cta-border);
  border-radius: var(--sai-eujkvafn-card-radius);
  padding: 1rem 1.25rem;
  font: inherit;
  font-size: 1.0625rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: background 120ms ease, color 120ms ease, opacity 120ms ease;
}

.sai-eujkvafn__cta:hover:not(:disabled) {
  background: var(--sai-eujkvafn-cta-hover-bg);
  color: var(--sai-eujkvafn-cta-hover-fg);
}

.sai-eujkvafn__cta:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.sai-eujkvafn__error {
  margin-block-start: var(--sai-size-2);
  padding: var(--sai-size-2) var(--sai-size-3);
  background: rgba(197, 48, 48, 0.08);
  color: var(--sai-color-error, #c53030);
  border-radius: var(--sai-radius-2);
  font-size: 0.8125rem;
}

/* Vertical: CTA stacks label + inline total vertically. */
.sai-eujkvafn--vertical .sai-eujkvafn__cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  text-align: center;
  line-height: 1.2;
  margin-block-start: var(--sai-size-4);
}

/* The loader is positioned absolute and must keep its own flex display so the
   spinner stays centered. Excluding it from this rule preserves both. */
.sai-eujkvafn--vertical .sai-eujkvafn__cta > span:not(.sai-eujkvafn__loader) {
  display: block;
}

.sai-eujkvafn--vertical .sai-eujkvafn__total--inline {
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  opacity: 0.92;
}

.sai-eujkvafn--vertical .sai-eujkvafn__total-inline-label {
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-weight: 600;
}

.sai-eujkvafn--vertical .sai-eujkvafn__total-separator {
  opacity: 0.6;
}

/* Hide the inline total line entirely when no amount is rendered yet. */
.sai-eujkvafn--vertical .sai-eujkvafn__total--inline:has(.sai-eujkvafn__total-amount:empty) {
  display: none;
}

/* Horizontal: right-side total panel layout. */
.sai-eujkvafn--horizontal .sai-eujkvafn__total--panel {
  display: flex;
  flex-direction: column;
  gap: var(--sai-size-3);
  padding-inline: var(--sai-size-2);
  align-self: stretch;
  justify-content: flex-start;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__cta {
  background: var(--sai-eujkvafn-cta-hover-bg);
  color: var(--sai-eujkvafn-cta-hover-fg);
  border: none;
  margin-block-start: auto;
  padding: 1.125rem var(--sai-size-4);
}

.sai-eujkvafn--horizontal .sai-eujkvafn__cta:hover:not(:disabled) {
  background: var(--sai-eujkvafn-cta-bg);
  color: var(--sai-eujkvafn-cta-fg);
  border: 1.5px solid var(--sai-eujkvafn-cta-border);
}

.sai-eujkvafn--horizontal .sai-eujkvafn__cta:disabled {
  opacity: 0.45;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__total-heading {
  font-size: 1.5rem;
  font-weight: var(--sai-font-body-weight-bold, 700);
  letter-spacing: -0.01em;
  line-height: 1.2;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__total-subtext {
  font-size: 0.875rem;
  color: var(--sai-eujkvafn-muted-fg);
  line-height: 1.4;
  text-align: start;
  flex: 0 1 auto;
  min-inline-size: 0;
}

.sai-eujkvafn--horizontal .sai-eujkvafn__total-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--sai-size-3);
  flex-wrap: nowrap;
}

@media (max-width: 540px) {
  .sai-eujkvafn--horizontal .sai-eujkvafn__total-row {
    flex-wrap: wrap;
  }
}

.sai-eujkvafn--horizontal .sai-eujkvafn__total-amount {
  margin-inline-start: auto;
  font-family: var(--sai-font-heading, var(--sai-font-body));
  font-size: 2rem;
  font-weight: var(--sai-font-body-weight-bold, 700);
  letter-spacing: -0.01em;
  text-align: start;
}

/* ── Modal ───────────────────────────────────────────────────────────────── */

.sai-eujkvafn__modal-overlay {
  position: fixed;
  inset: 0;
  background: var(--sai-eujkvafn-modal-overlay-bg);
  display: flex;
  align-items: center;
