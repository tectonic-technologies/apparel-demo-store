{% stylesheet %}
  .spectrum-compare-slot__inner {
    box-sizing: border-box;
    margin-inline: auto;
  }
  .spectrum-compare-slot__title {
    margin: 0 0 1.5rem;
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Spectrum Virtual Compare",
  "tag": "section",
  "blocks": [{ "type": "@theme" }, { "type": "@app" }],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "Shown as a heading above the compare experience.",
      "default": "Virtual Compare"
    },
    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum content width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "info": "Left and right gutters inside the content width.",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "info": "Keeps the section from collapsing on a published-but-empty page. Leave at 0 to size to content.",
      "min": 0,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 0
    },
    { "type": "header", "content": "Section padding" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}