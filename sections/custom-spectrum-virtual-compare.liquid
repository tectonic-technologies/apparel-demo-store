{% comment %}
  Spectrum: custom-spectrum-virtual-compare
  Container for the Virtual Compare page. Add the real snippet or app block into
  this section from the theme editor. The title and layout are
  merchant-configurable via the section settings.
{% endcomment %}

<section
  class="spectrum-compare-slot"
  style="min-height: {{ section.settings.min_height }}px; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div
    class="spectrum-compare-slot__inner"
    style="max-width: {{ section.settings.max_width }}px; padding-inline: {{ section.settings.padding_horizontal }}px;"
  >
    <h2 class="spectrum-compare-slot__title">{{ section.settings.title | escape }}</h2>

