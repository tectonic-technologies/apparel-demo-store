{% comment %}
  Spectrum: custom-spectrum-virtual-compare
  Container for the Virtual Compare page. Add the real snippet or app block into
  this section from the theme editor. The title and layout are
  merchant-configurable via the section settings.
{% endcomment %}

<section
  class="spectrum-compare-slot"
  style="min-height: {{ section.settings.min_height }}px; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div
    class="spectrum-compare-slot__inner"
    style="max-width: {{ section.settings.max_width }}px; padding-inline: {{ section.settings.padding_horizontal }}px;"
  >
    <h2 class="spectrum-compare-slot__title">{{ section.settings.title | escape }}</h2>
    {% content_for 'blocks' %}
  </div>
</section>

{% stylesheet %}
  .spectrum-compare-slot__inner {
    box-sizing: border-box;
    margin-inline: auto;
  }
  .spectrum-compare-slot__title {
    margin: 0 0 1.5rem;
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Spectrum Virtual Compare",
  "tag": "section",
  "blocks": [{ "type": "@theme" }, { "type": "@app" }],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "Shown as a heading above the compare experience.",
      "default": "Virtual Compare"
    },
    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum content width",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "info": "Left and right gutters inside the content width.",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "info": "Keeps the section from collapsing on a published-but-empty page. Leave at 0 to size to content.",
      "min": 0,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 0
    },
    { "type": "header", "content": "Section padding" },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}